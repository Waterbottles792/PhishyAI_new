# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Database
DATABASE_PATH=./data/phishguard.db

# Model Configuration
DEFAULT_MODEL=random_forest
MODEL_PATH=./data/models

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: If you want to use OpenAI GPT for advanced NLP features (not required for basic functionality)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: For advanced sentiment analysis APIs (TextBlob is used by default - no key needed)
# SENTIMENT_API_KEY=your_key_here

# Logging
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Feature Extraction Settings
ENABLE_GRAMMAR_CHECK=true
MAX_GRAMMAR_ERRORS=50
